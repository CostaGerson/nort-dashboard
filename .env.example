# ====================================================
# Nort Dashboard — variáveis de ambiente
# COPIE este arquivo para `.env` e ajuste os valores.
# NÃO subir o `.env` real para o GitHub.
# ====================================================

# --- Banco de dados PostgreSQL ---
POSTGRES_USER=nort
POSTGRES_PASSWORD=troque_esta_senha_forte
POSTGRES_DB=nortdb

# --- App Next.js / NextAuth ---
# Gerar um valor aleatório de 32+ caracteres para AUTH_SECRET
# (No PC com Node: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`)
AUTH_SECRET=troque_por_uma_string_aleatoria_longa_de_32_caracteres_no_minimo

# URL pública do dashboard
NEXTAUTH_URL=https://dashboard.nortsports.com.br

# Quando rodar localmente no PC para testar (opcional):
# NEXTAUTH_URL=http://localhost:3120
